FROM node:20-alpine

WORKDIR /app

# Copy lockfiles
COPY package*.json ./
COPY backend/package*.json ./backend/

# Install ALL dependencies (including devDependencies)
RUN npm install

# Copy source
COPY backend/ ./backend/

EXPOSE ${PORT:-3000}

# Run in watch mode
CMD ["npm", "run", "start:dev", "-w", "backend"]
